# ─────────────────────────────────────────────
# CORE
# ─────────────────────────────────────────────

# Django secret key — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to 1 for local development, 0 for production
DEBUG=1

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DB_URL=postgresql://user:password@localhost:5432/afrivate

# ─────────────────────────────────────────────
# URLS & HOSTS
# ─────────────────────────────────────────────

# Comma-separated list of allowed hostnames (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# Public URL of the backend (used in emails and redirects)
SITE_DOMAIN=https://your-backend.up.railway.app

# Public URL of the frontend (used in CORS and redirect links)
FRONTEND_URL=https://your-frontend.vercel.app

# ─────────────────────────────────────────────
# EMAIL
# ─────────────────────────────────────────────

# Sender address shown on all outgoing emails
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Django email framework backend (used by send_mail / EmailMessage calls)
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Resend API key — used by the Authentication app for OTP emails
# Get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# SendGrid API key — used by the Waitlist app for signup/welcome emails
# Get one at https://sendgrid.com
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# FILE STORAGE — CLOUDINARY
# ─────────────────────────────────────────────

# All three values are required for profile pictures and credential uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─────────────────────────────────────────────
# SOCIAL AUTH — GOOGLE
# ─────────────────────────────────────────────

# OAuth 2.0 credentials from Google Cloud Console
# Required for /api/auth/google/pathfinder/ and /api/auth/google/enabler/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─────────────────────────────────────────────
# CACHE & TASK QUEUE — REDIS
# ─────────────────────────────────────────────

# Redis URL used by both Django cache and Celery broker/result backend
# Defaults to redis://127.0.0.1:6379/1 if not set
REDIS_URL=redis://127.0.0.1:6379/1
